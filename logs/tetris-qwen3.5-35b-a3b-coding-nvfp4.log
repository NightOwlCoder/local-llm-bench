Here is a complete, single-file HTML solution. I have focused on a "Neon/Cyberpunk" aesthetic with smooth animations, rounded corners, and a clean user interface.

Save the following code as `tetris.html` and open it in your browser.

```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Neon Tetris</title>
    <style>
        :root {
            --bg-color: #1a1a2e;
            --grid-color: #16213e;
            --text-color: #e94560;
            --ui-bg: #0f3460;
            --accent: #e94560;
            
            /* Tetris Colors */
            --c-I: #00f0f0;
            --c-O: #f0f000;
            --c-T: #a000f0;
            --c-S: #00f000;
            --c-Z: #f00000;
            --c-J: #0000f0;
            --c-L: #f0a000;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-color);
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
            user-select: none;
        }

        .game-container {
            display: flex;
            gap: 20px;
            padding: 20px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 15px;
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
            backdrop-filter: blur(10px);
        }

        canvas {
            border: 2px solid var(--ui-bg);
            border-radius: 4px;
            background-color: var(--grid-color);
            box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
        }

        .sidebar {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            width: 150px;
        }

        .header {
            text-align: center;
            margin-bottom: 20px;
        }

        h1 {
            margin: 0;
            font-size: 2rem;
            color: var(--text-color);
            text-shadow: 0 0 10px var(--text-color);
            letter-spacing: 2px;
        }

        .score-box {
            background: var(--ui-bg);
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.2);
        }

        .score-label {
            font-size: 0.8rem;
            color: #aaa;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .score-val {
            font-size: 1.8rem;
            font-weight: bold;
            margin-top: 5px;
        }

        .controls-info {
            font-size: 0.8rem;
            color: #888;
            line-height: 1.6;
            margin-top: auto;
        }

        .key {
            display: inline-block;
            background: #333;
            padding: 2px 6px;
            border-radius: 4px;
            font-family: monospace;
            border-bottom: 2px solid #111;
        }

        #start-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(26, 26, 46, 0.9);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 10;
            border-radius: 15px;
        }

        .btn {
            background: var(--accent);
            color: white;
            border: none;
            padding: 15px 40px;
            font-size: 1.2rem;
            border-radius: 30px;
            cursor: pointer;
            transition: transform 0.1s, box-shadow 0.2s;
            box-shadow: 0 0 15px var(--accent);
            text-transform: uppercase;
            font-weight: bold;
            letter-spacing: 1px;
        }

        .btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 25px var(--accent);
        }

        .btn:active {
            transform: scale(0.95);
        }

        .game-over-text {
            font-size: 2.5rem;
            color: var(--text-color);
            margin-bottom: 20px;
            text-shadow: 0 0 10px var(--text-color);
        }

        /* Responsive adjustment for mobile */
        @media (max-width: 600px) {
            .game-container {
                flex-direction: column;
                align-items: center;
            }
            .sidebar {
                width: 100%;
                flex-direction: row;
                justify-content: space-around;
            }
            .controls-info {
                display: none;
            }
        }
    </style>
</head>
<body>

    <div class="game-container">
        <canvas id="tetris" width="240" height="400"></canvas>
        
        <div class="sidebar">
            <div class="header">
                <h1>TETRIS</h1>
            </div>
            
            <div class="score-box">
                <div class="score-label">Score</div>
                <div id="score" class="score-val">0</div>
            </div>

            <div class="controls-info">
                <div><span class="key">←</span> <span class="key">→</span> Move</div>
                <div><span class="key">↑</span> Rotate</div>
                <div><span class="key">↓</span> Soft Drop</div>
            </div>
        </div>
    </div>

    <div id="start-overlay">
        <button class="btn" onclick="startGame()">Play Game</button>
    </div>

    <script>
        const canvas = document.getElementById('tetris');
        const context = canvas.getContext('2d');
        const scoreElement = document.getElementById('score');
        const overlay = document.getElementById('start-overlay');

        // Scale up everything by 20 (block size)
        context.scale(20, 20);

        // Game State
        let dropCounter = 0;
        let dropInterval = 1000;
        let lastTime = 0;
        let isGameOver = false;
        let isPaused = true;

        // Colors mapped to shapes
        const colors = [
            null,
            '#FF0D72', // T (Purple-ish)
            '#0DC2FF', // I (Cyan)
            '#0DFF72', // S (Green)
            '#F538FF', // Z (Pinkish/Red)
            '#FF8E0D', // L (Orange)
            '#FFE138', // O (Yellow)
            '#3877FF', // J (Blue)
        ];

        // The Arena (The Grid)
        const arena = createMatrix(12, 20);

        // The Player
        const player = {
            pos: {x: 0, y: 0},
            matrix: null,
            score: 0,
        };

        function createMatrix(w, h) {
            const matrix = [];
            while (h--) {
                matrix.push(new Array(w).fill(0));
            }
            return matrix;
        }

        function createPiece(type) {
            if (type === 'I') {
                return [
                    [0, 1, 0, 0],
                    [0, 1, 0, 0],
                    [0, 1, 0, 0],
                    [0, 1, 0, 0],
                ];
            } else if (type === 'L') {
                return [
                    [0, 2, 0],
                    [0, 2, 0],
                    [0, 2, 2],
                ];
            } else if (type === 'J') {
                return [
                    [0, 3, 0],
                    [0, 3, 0],
                    [3, 3, 0],
                ];
            } else if (type === 'O') {
                return [
                    [4, 4],
                    [4, 4],
                ];
            } else if (type === 'Z') {
                return [
                    [5, 5, 0],
                    [0, 5, 5],
                    [0, 0, 0],
                ];
            } else if (type === 'S') {
                return [
                    [0, 6, 6],
                    [6, 6, 0],
                    [0, 0, 0],
                ];
            } else if (type === 'T') {
                return [
                    [0, 7, 0],
                    [7, 7, 7],
                    [0, 0, 0],
                ];
            }
        }

        // Draw a single block with rounded corners and glow
        function drawBlock(context, x, y, colorIndex) {
            const color = colors[colorIndex];
            
            // Glow effect
            context.shadowBlur = 10;
            context.shadowColor = color;
            
            // Draw the rounded rect
            context.fillStyle = color;
            
            // Slight inset for a 3D feel
            context.fillRect(x + 0.1, y + 0.1, 0.8, 0.8);
            
            // Reset shadow for performance
            context.shadowBlur = 0;
            
            // Inner highlight
            context.fillStyle = 'rgba(255,255,255,0.2)';
            context.fillRect(x + 0.2, y + 0.2, 0.2, 0.2);
        }

        function draw() {
            // Clear canvas
            context.fillStyle = '#16213e'; // Match CSS var --grid-color
            context.fillRect(0, 0, canvas.width, canvas.height);

            // Draw the Arena (locked pieces)
            drawMatrix(arena, {x: 0, y: 0}, context);
            
            // Draw the Player (active piece)
            drawMatrix(player.matrix, player.pos, context);
        }

        function drawMatrix(matrix, offset, ctx) {
            matrix.forEach((row, y) => {
                row.forEach((value, x) => {
                    if (value !== 0) {
                        drawBlock(ctx, x + offset.x, y + offset.y, value);
                    }
                });
            });
        }

        function merge(arena, player) {
            player.matrix.forEach((row, y) => {
                row.forEach((value, x) => {
                    if (value !== 0) {
                        arena[y + player.pos.y][x + player.pos.x] = value;
                    }
                });
            });
        }

        function rotate(matrix, dir) {
            for (let y = 0; y < matrix.length; ++y) {
                for (let x = 0; x < y; ++x) {
                    [matrix[x][y], matrix[y][x]] = [matrix[y][x], matrix[x][y]];
                }
            }
            if (dir > 0) {
                matrix.forEach(row => row.reverse());
            } else {
                matrix.reverse();
            }
        }

        function playerRotate(dir) {
            const pos = player.pos.x;
            let offset = 1;
            rotate(player.matrix, dir);
            // Wall kick logic (prevent rotating into walls)
            while (collide(arena, player)) {
                player.pos.x += offset;
                offset = -(offset + (offset > 0 ? 1 : -1));
                if (offset > player.matrix[0].length) {
                    rotate(player.matrix, -dir);
                    player.pos.x = pos;
                    return;
                }
            }
        }

        function collide(arena, player) {
            const m = player.matrix;
            const o = player.pos;
            for (let y = 0; y < m.length; ++y) {
                for (let x = 0; x < m[y].length; ++x) {
                    if (m[y][x] !== 0 &&
                       (arena[y + o.y] && arena[y + o.y][x + o.x]) !== 0) {
                        return true;
                    }
                }
            }
            return false;
        }

        function playerReset() {
            const pieces = 'ILJOTSZ';
            player.matrix = createPiece(pieces[pieces.length * Math.random() | 0]);
            player.pos.y = 0;
            player.pos.x = (arena[0].length / 2 | 0) - (player.matrix[0].length / 2 | 0);
            
            // Game Over check immediately upon reset
            if (collide(arena, player)) {
                isGameOver = true;
                isPaused = true;
                overlay.innerHTML = `<div class="game-over-text">Game Over</div><button class="btn" onclick="resetGame()">Try Again</button>`;
                overlay.style.display = 'flex';
            }
        }

        function arenaSweep() {
            let rowCount = 1;
            outer: for (let y = arena.length - 1; y > 0; --y) {
                for (let x = 0; x < arena[y].length; ++x) {
                    if (arena[y][x] === 0) {
                        continue outer;
                    }
                }

                const row = arena.splice(y, 1)[0].fill(0);
                arena.unshift(row);
                ++y;

                player.score += rowCount * 10;
                rowCount *= 2;
            }
            updateScore();
        }

        function playerDrop() {
            player.pos.y++;
            if (collide(arena, player)) {
                player.pos.y--;
                merge(arena, player);
                playerReset();
                arenaSweep();
                updateScore();
            }
            dropCounter = 0;
        }

        function playerMove(dir) {
            player.pos.x += dir;
            if (collide(arena, player)) {
                player.pos.x -= dir;
            }
        }

        function updateScore() {
            scoreElement.innerText = player.score;
        }

        function update(time = 0) {
            if (isPaused) return;

            const deltaTime = time - lastTime;
            lastTime = time;

            dropCounter += deltaTime;
            if (dropCounter > dropInterval) {
                playerDrop();
            }

            draw();
            requestAnimationFrame(update);
        }

        function startGame() {
            overlay.style.display = 'none';
            resetGame();
            isPaused = false;
            update();
        }

        function resetGame() {
            arena.forEach(row => row.fill(0));
            player.score = 0;
            updateScore();
            playerReset();
            isGameOver = false;
            isPaused = false;
            dropInterval = 1000;
            update();
        }

        // Controls
        document.addEventListener('keydown', event => {
            if (isPaused) return;

            if (event.keyCode === 37) { // Left
                playerMove(-1);
            } else if (event.keyCode === 39) { // Right
                playerMove(1);
            } else if (event.keyCode === 40) { // Down
                playerDrop();
            } else if (event.keyCode === 38) { // Up (Rotate)
                playerRotate(1);
            }
        });

        // Initial Draw
        draw();
    </script>
</body>
</html>
```
