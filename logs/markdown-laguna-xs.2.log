    <div class="container">
        <div class="panel">
            <div class="panel-header">
                <div class="icon"></div>
                <h2>Markdown Editor</h2>
            </div>
            <textarea id="editor" placeholder="Enter your markdown here...">
# Welcome to Markdown Previewer

This is a **beautiful** markdown previewer with live preview!

## Features Supported

- # Headers (h1-h6)
- **Bold** and *italic* text
- `Inline code` and code blocks:
```
function hello() {
  console.log("Hello World!");
}
```
- Lists:
  - Unordered list item 1
  - Unordered list item 2
  1. Ordered list item 1
  2. Ordered list item 2
- [Links](https://example.com)

---

Try editing this text to see the live preview on the right!</textarea>
        </div>
        
        <div class="panel">
            <div class="panel-header">
                <div class="icon"></div>
                <h2>Preview</h2>
            </div>
            <div id="preview" class="preview"></div>
        </div>
    </div>
    
    <div class="instructions">
        <h3>Supported Markdown</h3>
        <ul>
            <li># Headers (h1-h6)</li>
            <li><strong>Bold</strong> and <em>italic</em></li>
            <li>Inline <code>code</code></li>
            <li>Code blocks with ```</li>
            <li>Ordered and unordered lists</li>
            <li>[Links](url)</li>
        </ul>
    </div>

    <script>
        const editor = document.getElementById('editor');
        const preview = document.getElementById('preview');
        
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        function highlightCode(text) {
            return text.replace(/```[\s\S]*?```/g, match => {
                const code = match.slice(3, -3);
                return `<pre><code>${escapeHtml(code)}</code></pre>`;
            });
        }
        
        function parseInlineCode(text) {
            return text.replace(/`[^`]+`/g, match => {
                const code = match.slice(1, -1);
                return `<code>${escapeHtml(code)}</code>`;
            });
        }
        
        function parseLinks(text) {
            return text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
        }
        
        function parseBold(text) {
            return text.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        }
        
        function parseItalic(text) {
            return text.replace(/\*([^*]+)\*/g, '<em>$1</em>');
        }
        
        function parseHeaders(text) {
            return text.replace(/^(#{1,6})\s+(.+)$/gm, (match, hashes, content) => {
                const level = hashes.length;
                return `<h${level}>${content}</h${level}>`;
            });
        }
        
        function parseLists(text) {
            const lines = text.split('\n');
            let result = [];
            let currentList = null;
            let listType = null;
            
            lines.forEach(line => {
                const orderedMatch = line.match(/^(\d+)\.\s+(.+)$/);
                const unorderedMatch = line.match(/^[-*]\s+(.+)$/);
                
                if (orderedMatch) {
                    if (listType !== 'ol') {
                        if (currentList) result.push(`</${listType}>`);
                        result.push('<ol>');
                        currentList = [];
                        listType = 'ol';
                    }
                    currentList.push(`<li>${orderedMatch[2]}</li>`);
                } else if (unorderedMatch) {
                    if (listType !== 'ul') {
                        if (currentList) result.push(`</${listType}>`);
                        result.push('<ul>');
                        currentList = [];
                        listType = 'ul';
                    }
                    currentList.push(`<li>${unorderedMatch[1]}</li>`);
                } else {
                    if (currentList) {
                        result.push(`</${listType}>`);
                        currentList = null;
                        listType = null;
                    }
                    result.push(line);
                }
            });
            
            if (currentList) {
                result.push(`</${listType}>`);
            }
            
            return result.join('\n');
        }
        
        function parseBreaks(text) {
            return text.replace(/---/g, '<hr>');
        }
        
        function updatePreview() {
            let content = editor.value;
            
            // Parse in correct order
            content = parseHeaders(content);
            content = parseBreaks(content);
            content = highlightCode(content);
            content = parseInlineCode(content);
            content = parseLinks(content);
            content = parseBold(content);
            content = parseItalic(content);
            content = parseLists(content);
            
            // Wrap in paragraphs
            const lines = content.split('\n');
            let html = '';
            for (let line of lines) {
                line = line.trim();
                if (line === '') {
                    html += '\n';
                } else if (!line.startsWith('<h') && !line.startsWith('<ul') && !line.startsWith('<ol') && !line.startsWith('</') && !line.startsWith('<hr')) {
                    html += `<p>${line}</p>\n`;
                } else {
                    html += line + '\n';
                }
            }
            
            preview.innerHTML = html;
        }
        
        editor.addEventListener('input', updatePreview);
        updatePreview(); // Initial render
    </script>
</body>
</html>
