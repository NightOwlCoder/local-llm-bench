        button {
            border: none;
            border-radius: 12px;
            padding: 20px 5px;
            font-size: 20px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s ease;
            color: #fff;
        }
        
        button:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        }
        
        button:active {
            transform: translateY(0);
        }
        
        .number { background: linear-gradient(135deg, #4e54c8, #8f94fb); }
        .operator { background: linear-gradient(135deg, #ff6b6b, #eea849); }
        .function { background: linear-gradient(115deg, #43e97b, #38f9d7); }
        .equals { background: linear-gradient(135deg, #fa709a, #fee140); }
        .clear { background: linear-gradient(135deg, #d31928, #ff416c); }
        
        .title {
            text-align: center;
            color: #fff;
            margin-bottom: 20px;
            font-size: 28px;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
